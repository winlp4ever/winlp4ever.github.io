---
import BaseLayout from '../layouts/BaseLayout.astro'

const profile = {
  name: 'Ha-Quang Le',
  role: 'Lead AI Engineer',
  location: 'Paris',
  bio: "AI engineer with interests in building useful apps and scalable AI systems. I also love to draw and play PES in my free time (and Age of Empires, but I'm null at it). Root for Barça and Arsenal, both teams, all the way.",
  links: [
    { label: 'github', handle: 'github.com/winlp4ever', href: 'https://github.com/winlp4ever' },
    {
      label: 'linkedin',
      handle: 'linkedin.com/in/ha-quang-le',
      href: 'https://www.linkedin.com/in/ha-quang-le',
    },
    { label: 'email', handle: 'winlp4ever@gmail.com', href: 'mailto:winlp4ever@gmail.com' },
  ],
}
---

<BaseLayout title={`${profile.name} — ${profile.role}`}>
  <main class="page">
    <header class="masthead">
      <h1 class="name">{profile.name}<span class="cursor"></span></h1>
      <p class="meta">{profile.role.toLowerCase()} * {profile.location.toLowerCase()}</p>
    </header>

    <section class="block">
      <p class="bio">{profile.bio}</p>
      <p class="bio-aside">
        Behind <a href="https://dim0.net" class="inline">dim0.net</a> — a thinking canvas.
      </p>
    </section>

    <section class="block">
      <h2 class="section-label">Elsewhere</h2>
      <ul class="link-list">
        {
          profile.links.map((l) => (
            <li class="link-row">
              <span class="link-label">{l.label}</span>
              <a href={l.href} class="inline">
                {l.handle}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <footer class="footer">
      <span>© 2026</span>
      <span>set in inconsolata</span>
    </footer>
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 72px 32px 96px;
  }

  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 56px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--hair);
  }

  .name {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: var(--ink);
    vertical-align: -0.12em;
    margin-left: 2px;
    animation: blink 1.1s steps(1) infinite;
  }

  .meta {
    font-size: 13px;
    color: var(--muted);
    margin: 0;
    white-space: nowrap;
  }

  .block {
    margin-bottom: 56px;
  }

  .bio {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink);
    margin: 0;
    text-wrap: pretty;
  }

  .bio-aside {
    font-size: 14px;
    line-height: 1.65;
    color: var(--muted);
    margin: 16px 0 0;
  }

  .section-label {
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 18px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .link-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: baseline;
    font-size: 15px;
  }

  .link-label {
    color: var(--muted);
  }

  .footer {
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    font-size: 12px;
    color: var(--faint);
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  @media (max-width: 520px) {
    .masthead {
      flex-direction: column;
      gap: 4px;
    }
    .link-row {
      grid-template-columns: 80px 1fr;
    }
  }
</style>
