---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { Content } = await render(post)

const dateLabel = post.data.date.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: '2-digit',
})
---

<BaseLayout title={`${post.data.title} — Ha-Quang Le`} description={post.data.description}>
  <main class="page">
    <nav class="topnav">
      <a href="/" class="back">← back</a>
    </nav>

    <header class="post-head">
      <p class="post-meta">{dateLabel}{post.data.tags.length ? ` · ${post.data.tags.join(', ')}` : ''}</p>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.description && <p class="post-desc">{post.data.description}</p>}
    </header>

    <article class="prose">
      <Content />
    </article>

    <footer class="footer">
      <a href="/" class="back">← back</a>
      <span>set in inconsolata</span>
    </footer>
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 32px 96px;
  }

  .topnav {
    margin-bottom: 56px;
    font-size: 13px;
    color: var(--muted);
  }

  .back {
    color: var(--muted);
  }
  .back:hover {
    color: var(--ink);
  }

  .post-head {
    margin-bottom: 56px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--hair);
  }

  .post-meta {
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 12px;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  .post-title {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .post-desc {
    font-size: 15px;
    color: var(--muted);
    margin: 14px 0 0;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .prose {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
  }

  .prose :global(h2) {
    font-size: 18px;
    font-weight: 700;
    margin: 56px 0 16px;
    letter-spacing: -0.005em;
  }

  .prose :global(h3) {
    font-size: 16px;
    font-weight: 700;
    margin: 40px 0 12px;
  }

  .prose :global(p) {
    margin: 0 0 20px;
    text-wrap: pretty;
  }

  .prose :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--faint);
  }
  .prose :global(a:hover) {
    border-bottom-color: var(--ink);
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4em;
    margin: 0 0 20px;
  }

  .prose :global(li) {
    margin: 4px 0;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin: 4px 0 4px;
  }

  .prose :global(code) {
    background: #f5f5f5;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.92em;
  }

  .prose :global(pre) {
    background: #fafafa;
    border: 1px solid var(--hair);
    border-radius: 6px;
    padding: 16px 18px;
    overflow-x: auto;
    margin: 0 0 24px;
    font-size: 13.5px;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--ink);
    margin: 24px 0;
    padding: 4px 0 4px 18px;
    color: var(--muted);
    font-style: italic;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 24px 0;
    border-radius: 4px;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--hair);
    margin: 40px 0;
  }

  .footer {
    margin-top: 72px;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    font-size: 12px;
    color: var(--faint);
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
</style>
